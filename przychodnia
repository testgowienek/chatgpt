-- =========================================
-- 1. TWORZENIE BAZY DANYCH
-- =========================================

CREATE DATABASE przychodnia_kowalski;
USE przychodnia_kowalski;

-- =========================================
-- 2. TABELA LEKARZE
-- =========================================

CREATE TABLE lekarze (
    ID_lekarzy INT AUTO_INCREMENT PRIMARY KEY,
    imie VARCHAR(25) NOT NULL,
    nazwisko VARCHAR(25) NOT NULL,
    specjalizacja VARCHAR(50) NOT NULL,
    adres_email VARCHAR(70) NOT NULL,
    nr_telefonu VARCHAR(9) NOT NULL,
    kod_pocztowy VARCHAR(6) NOT NULL,
    miejscowosc VARCHAR(30) NOT NULL,
    ulica VARCHAR(60),
    nr_domu INT(5) NOT NULL,
    nr_lokalu INT(5)
);

-- =========================================
-- 3. TABELA PACJENCI
-- =========================================

CREATE TABLE pacjenci (
    ID_pacjenci INT AUTO_INCREMENT PRIMARY KEY,
    imie VARCHAR(25) NOT NULL,
    nazwisko VARCHAR(25) NOT NULL,
    PESEL VARCHAR(11) NOT NULL UNIQUE,
    adres_email VARCHAR(70),
    nr_telefonu VARCHAR(9) NOT NULL
);

-- =========================================
-- 4. TABELA SWIADCZENIA
-- =========================================

CREATE TABLE swiadczenia (
    ID_swiadczenia INT AUTO_INCREMENT PRIMARY KEY,
    rodzaj_swiadczenia VARCHAR(50) NOT NULL,
    koszt_swiadczenia FLOAT NOT NULL
);

-- =========================================
-- 5. TABELA WIZYTY
-- =========================================

CREATE TABLE wizyty (
    ID_wizyty INT AUTO_INCREMENT PRIMARY KEY,
    rodzaj_swiadczenia INT NOT NULL,
    pacjent INT NOT NULL,
    lekarz INT NOT NULL,
    data_wizyty DATE NOT NULL,

    CONSTRAINT fk_swiadczenie
        FOREIGN KEY (rodzaj_swiadczenia)
        REFERENCES swiadczenia(ID_swiadczenia),

    CONSTRAINT fk_pacjent
        FOREIGN KEY (pacjent)
        REFERENCES pacjenci(ID_pacjenci),

    CONSTRAINT fk_lekarz
        FOREIGN KEY (lekarz)
        REFERENCES lekarze(ID_lekarzy)
);

